# GitHub token must stay server-side. Do not prefix with NEXT_PUBLIC_.
# Fine-grained PAT permissions: target repos -> Issues: Read and write.
GITHUB_TOKEN=<server-side-github-token>
GITHUB_OWNER=your-github-owner

# Public and private issue targets.
GITHUB_REPO=books-radar
GITHUB_PRIVATE_REPO=georgesbooks

# Optional.
GITHUB_API_VERSION=2022-11-28
BOOKS_REQUEST_ALLOWED_ORIGIN=
